{
  "$schema": "https://raw.githubusercontent.com/muxy-app/extensions/main/schema/manifest.schema.json",
  "name": "hello-world",
  "version": "0.1.0",
  "description": "Minimal Muxy extension: a palette command that opens a theme-aware tab.",
  "permissions": ["tabs:write", "notifications:write"],
  "tabTypes": [
    { "id": "main", "title": "Hello", "entry": "tabs/index.html" }
  ],
  "commands": [
    {
      "id": "open",
      "title": "Hello World: Open",
      "action": { "kind": "openTab", "tabType": "main" }
    }
  ],
  "marketplace": {
    "author": "Muxy",
    "homepage": "https://muxy.app",
    "categories": ["example"],
    "icon": "assets/icon.svg",
    "screenshots": ["assets/screenshot-1.png"]
  }
}
